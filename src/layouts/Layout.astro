---
import "../styles/global.css";
import { ThemeScript } from "astro-theme-toggle/components";
import SEOMeta from "./SEOMeta.astro";


interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogImageAlt?: string;
  canonical?: string;
  locale?: "en" | "ru";
}

const {
  title = "Doctor Wedding — We plan. You celebrate.",
  description,
  ogTitle,
  ogDescription,
  ogImage,
  ogImageAlt,
  canonical,
  locale = "en",
} = Astro.props;
---
<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <SEOMeta
    title={title}
    description={description}
    ogTitle={ogTitle}
    ogDescription={ogDescription}
    ogImage={ogImage}
    ogImageAlt={ogImageAlt}
    canonical={canonical}
    locale={locale}
  />
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=Great+Vibes&family=Playfair+Display:ital,wght@0,700;1,400;1,700&display=swap" rel="stylesheet">
  <ThemeScript />
</head>
<body>
  <slot />

  <script is:inline>
    function preloadThemeAssets() {
      const themeAssets = [
        "/images/hero/hero_backround_light.avif",
        "/images/hero/hero_backround_dark.avif",
        "/images/hero/hero_backround_light_mobile.avif",
        "/images/hero/hero_backround_dark_mobile.avif",
        "/images/logo/logo_light.avif",
        "/images/logo/logo_dark.avif",
      ];

      themeAssets.forEach(function(src) {
        const image = new Image();
        image.decoding = "async";
        image.src = src;
      });
    }

    requestAnimationFrame(function() {
      if ("requestIdleCallback" in window) {
        requestIdleCallback(preloadThemeAssets, { timeout: 1200 });
      } else {
        setTimeout(preloadThemeAssets, 250);
      }
    });
  </script>
</body>
</html>
