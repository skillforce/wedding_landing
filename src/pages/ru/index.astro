---
import CtaSection from "../../components/CtaSection.astro";
import FeaturesSection from "../../components/FeaturesSection.astro";
import ForWhoSection from "../../components/ForWhoSection.astro";
import HeroSection from "../../components/HeroSection.astro";
import PricingSection from "../../components/PricingSection.astro";
import ReviewsSection from "../../components/ReviewsSection/index.astro";
import ShowcaseSection from "../../components/ShowcaseSection/index.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { ru } from "../../i18n/translations";
import Layout from "../../layouts/Layout.astro";

const t = ru;
---
<Layout locale="ru" title="Doctor Wedding — Мы планируем. Вы празднуете.">
  <SiteHeader t={t} />
  <HeroSection t={t} />
  <FeaturesSection t={t} />
  <ShowcaseSection t={t} />
  <ForWhoSection t={t} />
  <PricingSection t={t} />
  <ReviewsSection locale={t.locale} />
  <CtaSection t={t} />
  <SiteFooter t={t} />
</Layout>
