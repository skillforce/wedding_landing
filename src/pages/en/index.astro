---
import CtaSection from "../../components/CtaSection.astro";
import FeaturesSection from "../../components/FeaturesSection.astro";
import ForWhoSection from "../../components/ForWhoSection.astro";
import HeroSection from "../../components/HeroSection.astro";
import PricingSection from "../../components/PricingSection.astro";
import ReviewsSection from "../../components/ReviewsSection/index.astro";
import ShowcaseSection from "../../components/ShowcaseSection/index.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { en } from "../../i18n/translations";
import Layout from "../../layouts/Layout.astro";

const t = en;
---
<Layout
  locale="en"
  title="Doctor Wedding — We Plan. You Celebrate."
  description="Wedding planning app with guest management, seating plans, multi-currency budget tracking, day-of timeline and checklists. For couples and wedding planners."
  ogTitle="Doctor Wedding — Smart Wedding Planning"
  ogDescription="Guests & seating, multi-currency budget, day timeline and checklists — everything for a perfect wedding in one place."
  ogImageAlt="Doctor Wedding — wedding planning app"
  canonical="https://doctor-wedding.com/en/"
>
  <SiteHeader t={t} />
  <HeroSection t={t} />
  <FeaturesSection t={t} />
  <ShowcaseSection t={t} />
  <ForWhoSection t={t} />
  <PricingSection t={t} />
  <ReviewsSection locale={t.locale} />
  <CtaSection t={t} />
  <SiteFooter t={t} />
</Layout>
