---
import { type ButtonHtmlType, type ButtonSize, ButtonType } from "./Button.types";

interface Props {
  type?: ButtonType;
  size?: ButtonSize;
  htmlType?: ButtonHtmlType;
  fullWidth?: boolean;
}

const {
  type = ButtonType.Primary,
  size = "md",
  htmlType = "button",
  fullWidth = false,
} = Astro.props;
---

<button
  type={htmlType}
  class:list={[
    'button',
    `button-${type}`,
    `button-${size}`,
    { 'button-full': fullWidth },
  ]}
>
  <slot />
</button>

<style>
  .button {
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    font-weight: 600;
    cursor: pointer;
    transition: 0.2s;
  }

  .button-md { gap: 8px; padding: 11px 22px; border-radius: 6px; font-size: 13.5px; }
  .button-lg { gap: 8px; padding: 13px 28px; border-radius: 8px; font-size: 14px; }
  .button-compact { gap: 6px; padding: 11px; border-radius: 8px; font-size: 13px; }
  .button-full { width: 100%; }

  .button-primary { background: var(--teal-dark); color: #fff; }
  .button-primary:hover { background: var(--teal); }
  :global(html.dark) .button-primary { background: var(--gold); color: var(--navy); }
  :global(html.dark) .button-primary:hover { background: var(--gold-bright); }

  .button-secondary {
    background: transparent;
    border: 1.5px solid var(--text-dark);
    color: var(--text-dark);
  }
  .button-secondary:hover { background: rgba(0,0,0,.05); }
  .button-secondary.button-compact.button-full {
    background: var(--ivory2);
    border: 1px solid var(--border);
  }
  .button-secondary.button-compact.button-full:hover { background: var(--border); }
  :global(html.dark) .button-secondary {
    border-color: rgba(255,255,255,.35);
    color: #fff;
  }
  :global(html.dark) .button-secondary:hover { background: rgba(255,255,255,.07); }
</style>
