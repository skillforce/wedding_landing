---
interface Props {
  size?: number;
  showStar?: boolean;
}
const { size = 44, showStar = true } = Astro.props;
---
<svg class="logo-icon" width={size} height={size} viewBox="0 0 44 44" fill="none">
  <circle class="logo-ring-left" cx="16" cy="22" r="10" stroke-width="2.5" fill="none"/>
  <circle class="logo-ring-right" cx="28" cy="22" r="10" stroke-width="2.5" fill="none"/>
  {showStar && (
    <path class="logo-ring-star"
      d="M22 17.5 L24 21 L28 21.5 L25 24 L25.5 28 L22 26 L18.5 28 L19 24 L16 21.5 L20 21 Z"
    />
  )}
</svg>

<style>
  .logo-ring-left { stroke: #d9b98c; }
  .logo-ring-right { stroke: var(--gold); }
  .logo-ring-star { fill: #d9b98c; opacity: 0.7; }

  :global(html.dark) .logo-ring-left { stroke: var(--gold); }
  :global(html.dark) .logo-ring-right { stroke: #b8943f; }
  :global(html.dark) .logo-ring-star { fill: var(--gold); opacity: 0.8; }
</style>
