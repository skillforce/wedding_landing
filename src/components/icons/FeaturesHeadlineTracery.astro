<svg
  class="features-headline-tracery"
  viewBox="0 0 720 260"
  fill="none"
  preserveAspectRatio="xMidYMid meet"
  aria-hidden="true"
>
  <defs>
    <linearGradient id="features-tracery-main" x1="70" y1="210" x2="650" y2="34" gradientUnits="userSpaceOnUse">
      <stop class="tracery-stop-soft" offset="0" />
      <stop class="tracery-stop-bright" offset="0.5" />
      <stop class="tracery-stop-soft" offset="1" />
    </linearGradient>
    <linearGradient id="features-tracery-thread" x1="120" y1="52" x2="600" y2="220" gradientUnits="userSpaceOnUse">
      <stop class="tracery-stop-muted" offset="0" />
      <stop class="tracery-stop-bright" offset="0.5" />
      <stop class="tracery-stop-muted" offset="1" />
    </linearGradient>
  </defs>

  <g>
    <path class="tracery-line tracery-hero" d="M40 182 C128 68 230 40 360 128 C490 40 592 68 680 182" />
    <path class="tracery-line tracery-delay-1" d="M88 220 C178 150 242 132 360 168 C478 132 542 150 632 220" />
    <path class="tracery-line tracery-delay-2" d="M122 72 C220 142 290 170 360 128 C430 170 500 142 598 72" />
    <path class="tracery-line tracery-fine tracery-delay-3" d="M196 226 C230 160 278 98 360 54 C442 98 490 160 524 226" />
    <path class="tracery-line tracery-fine tracery-delay-1" d="M176 118 C244 94 306 100 360 128 C414 100 476 94 544 118" />
    <path class="tracery-line tracery-fine tracery-delay-2" d="M150 184 C238 196 302 196 360 168 C418 196 482 196 570 184" />
  </g>

  <g class="tracery-glints">
    <path class="tracery-glint" d="M196 226 C256 164 302 136 360 128 C418 136 464 164 524 226" />
    <path class="tracery-glint tracery-delay-2" d="M122 72 C226 112 300 112 360 54 C420 112 494 112 598 72" />
  </g>

  <g class="tracery-dots">
    <circle cx="360" cy="54" r="2.8" />
    <circle cx="360" cy="128" r="3.2" />
    <circle cx="360" cy="168" r="2.4" />
    <circle cx="176" cy="118" r="2.2" />
    <circle cx="544" cy="118" r="2.2" />
    <circle cx="88" cy="220" r="2" />
    <circle cx="632" cy="220" r="2" />
  </g>
</svg>

<style>
  .features-headline-tracery {
    display: block;
    width: 100%;
    height: 100%;
    color: #2a4e4a;
    --tracery-soft: rgba(42, 78, 74, .2);
    --tracery-muted: rgba(42, 78, 74, .44);
    --tracery-bright: rgba(42, 78, 74, .84);
    opacity: .24;
    animation: features-tracery-idle 12s ease-in-out infinite;
  }

  .tracery-stop-soft { stop-color: var(--tracery-soft); }
  .tracery-stop-muted { stop-color: var(--tracery-muted); }
  .tracery-stop-bright { stop-color: var(--tracery-bright); }

  .tracery-line,
  .tracery-glint {
    vector-effect: non-scaling-stroke;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .tracery-line {
    stroke: url(#features-tracery-main);
    stroke-width: 2;
  }

  .tracery-hero {
    stroke-width: 2.45;
  }

  .tracery-fine {
    stroke-width: 1.2;
    opacity: .78;
  }

  .tracery-glint {
    stroke: url(#features-tracery-thread);
    stroke-width: 1;
    opacity: .68;
  }

  .tracery-dots {
    fill: currentColor;
    opacity: .46;
  }

  .tracery-delay-1 { animation-delay: .12s, 2.02s; }
  .tracery-delay-2 { animation-delay: .24s, 2.14s; }
  .tracery-delay-3 { animation-delay: .36s, 2.26s; }

  :global(html.dark) .features-headline-tracery {
    color: var(--gold-bright);
    --tracery-soft: rgba(226, 185, 106, .18);
    --tracery-muted: rgba(226, 185, 106, .42);
    --tracery-bright: rgba(255, 222, 142, .88);
    opacity: .3;
  }

  @keyframes features-tracery-idle {
    0%, 100% { opacity: .2; }
    50% { opacity: .25; }
  }

  @media (prefers-reduced-motion: reduce) {
    .features-headline-tracery {
      animation: none;
    }
  }
</style>
