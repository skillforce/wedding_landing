---
interface Tab {
  label: string;
}

interface Props {
  tabs: Tab[];
}

const { tabs } = Astro.props;
---

<div class="tab-bar" role="tablist">
  {tabs.map((tab, i) => (
    <button
      class:list={["tab", { active: i === 0 }]}
      data-tab={i}
      role="tab"
      aria-selected={i === 0 ? "true" : "false"}
    >
      {tab.label}
    </button>
  ))}
</div>

<style>
  .tab-bar {
    display: flex;
    gap: 4px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 2px 0;
    min-width: 0;
  }
  .tab-bar::-webkit-scrollbar { display: none; }

  .tab {
    flex-shrink: 0;
    padding: 4px 11px;
    border-radius: 6px;
    border: none;
    background: transparent;
    font-size: 11.5px;
    font-weight: 500;
    color: var(--text-soft);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .tab:hover { background: rgba(0,0,0,.06); color: var(--text-dark); }
  .tab.active {
    background: #fff;
    color: var(--teal-dark);
    font-weight: 600;
    box-shadow: 0 1px 4px rgba(0,0,0,.10);
  }

  :global(html.dark) .tab { color: rgba(255,255,255,0.45); }
  :global(html.dark) .tab:hover { background: rgba(255,255,255,.06); color: rgba(255,255,255,.75); }
  :global(html.dark) .tab.active {
    background: rgba(255,255,255,.07);
    color: var(--gold);
    box-shadow: 0 1px 4px rgba(0,0,0,.25);
  }

  @media (max-width: 760px) {
    .tab { font-size: 11px; padding: 3px 9px; }
  }

  @media (max-width: 480px) {
    .tab { font-size: 10.5px; padding: 3px 8px; }
  }

  @media (max-width: 380px) {
    .tab { font-size: 10px; padding: 3px 6px; }
  }
</style>
