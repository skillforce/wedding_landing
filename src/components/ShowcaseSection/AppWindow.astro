---
import VideoTabs from "./VideoTabs.astro";

interface Tab {
  label: string;
  video: string;
}

interface Props {
  tabs: Tab[];
}

const { tabs } = Astro.props;
---

<div class="app-window">
  <VideoTabs tabs={tabs} />
</div>

<style>
  .app-window {
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.10), 0 2px 8px rgba(0, 0, 0, 0.06);
    background: #fff;
    width: 100%;
    max-width: 900px;
  }

  /* Dark mode */
  :global(html.dark) .app-window {
    background: rgba(22, 32, 54, 0.95);
    border-color: rgba(184, 148, 63, 0.22);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.35);
  }

  @media (max-width: 760px) {
    .app-window { border-radius: 12px; }
  }
</style>
