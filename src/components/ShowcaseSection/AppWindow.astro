---
interface Tab {
  label: string;
  image: string;
}

interface Props {
  tabs: Tab[];
}

const { tabs } = Astro.props;
const panelDots = ["panel-dot-red", "panel-dot-yellow", "panel-dot-gold"];
---

<div class="app-window">
  <div class="panel-header">
    <div class="traffic-lights">
      {panelDots.map(cls => <div class:list={["panel-dot", cls]}></div>)}
    </div>
    <div class="tab-bar" role="tablist">
      {tabs.map((tab, i) => (
        <button
          class:list={["tab", { active: i === 0 }]}
          data-tab={i}
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
        >
          {tab.label}
        </button>
      ))}
    </div>
  </div>
  <div class="panel-body">
    {tabs.map((tab, i) => (
      <img
        class:list={["tab-img", { active: i === 0 }]}
        src={tab.image}
        alt={tab.label}
        loading={i === 0 ? "eager" : "lazy"}
        draggable="false"
      />
    ))}
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>(".app-window").forEach(win => {
    const tabs = win.querySelectorAll<HTMLButtonElement>(".tab");
    const imgs = win.querySelectorAll<HTMLImageElement>(".tab-img");
    tabs.forEach((tab, i) => {
      tab.addEventListener("click", () => {
        tabs.forEach(t => { t.classList.remove("active"); t.setAttribute("aria-selected", "false"); });
        imgs.forEach(img => img.classList.remove("active"));
        tab.classList.add("active");
        tab.setAttribute("aria-selected", "true");
        imgs[i].classList.add("active");
      });
    });
  });
</script>

<style>
  .app-window {
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.10), 0 2px 8px rgba(0, 0, 0, 0.06);
    background: #fff;
  }

  .panel-header {
    padding: 10px 14px;
    background: var(--ivory);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .traffic-lights {
    display: flex;
    align-items: center;
    gap: 5px;
    flex-shrink: 0;
  }

  .panel-dot { width: 10px; height: 10px; border-radius: 50%; }
  .panel-dot-red    { background: #ff5f57; }
  .panel-dot-yellow { background: #ffbd2e; }
  .panel-dot-gold   { background: #c9a84c; }

  .tab-bar {
    display: flex;
    gap: 4px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 2px 0;
    min-width: 0;
  }
  .tab-bar::-webkit-scrollbar { display: none; }

  .tab {
    flex-shrink: 0;
    padding: 4px 11px;
    border-radius: 6px;
    border: none;
    background: transparent;
    font-size: 11.5px;
    font-weight: 500;
    color: var(--text-soft);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }
  .tab:hover { background: rgba(0,0,0,.06); color: var(--text-dark); }
  .tab.active {
    background: #fff;
    color: var(--teal-dark);
    font-weight: 600;
    box-shadow: 0 1px 4px rgba(0,0,0,.10);
  }

  .panel-body {
    position: relative;
    background: var(--ivory2);
    aspect-ratio: 16 / 7;
    overflow: hidden;
  }

  .tab-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }
  .tab-img.active { opacity: 1; }

  /* Dark mode */
  :global(html.dark) .app-window {
    background: rgba(22, 32, 54, 0.95);
    border-color: rgba(184, 148, 63, 0.22);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.35);
  }
  :global(html.dark) .panel-header {
    background: rgba(14, 20, 36, 0.8);
    border-bottom-color: rgba(184, 148, 63, 0.18);
  }
  :global(html.dark) .tab { color: rgba(255,255,255,0.45); }
  :global(html.dark) .tab:hover { background: rgba(255,255,255,.06); color: rgba(255,255,255,.75); }
  :global(html.dark) .tab.active {
    background: rgba(255,255,255,.07);
    color: var(--gold);
    box-shadow: 0 1px 4px rgba(0,0,0,.25);
  }
  :global(html.dark) .panel-body { background: rgba(10, 14, 26, 0.6); }

  @media (max-width: 760px) {
    .app-window { border-radius: 12px; }
    .panel-header { padding: 9px 12px; gap: 10px; }
    .panel-dot { width: 9px; height: 9px; }
    .tab { font-size: 11px; padding: 3px 9px; }
    .panel-body { aspect-ratio: 16 / 8; }
  }

  @media (max-width: 480px) {
    .tab { font-size: 10.5px; padding: 3px 8px; }
    .panel-body { aspect-ratio: 16 / 9; }
  }

  @media (max-width: 380px) {
    .panel-header { padding: 8px 10px; gap: 8px; }
    .panel-dot { width: 7px; height: 7px; }
    .traffic-lights { gap: 4px; }
    .tab { font-size: 10px; padding: 3px 6px; }
  }
</style>