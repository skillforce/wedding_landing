---
import VideoTabBar from "./VideoTabBar.astro";

interface Tab {
  label: string;
  video: string;
}

interface Props {
  tabs: Tab[];
}

const { tabs } = Astro.props;
const panelDots = ["panel-dot-red", "panel-dot-yellow", "panel-dot-gold"];
---

<div class="video-tabs" data-video-tabs>
  <div class="panel-header">
    <div class="traffic-lights">
      {panelDots.map(cls => <div class:list={["panel-dot", cls]}></div>)}
    </div>
    <VideoTabBar tabs={tabs} />
  </div>
  <div class="panel-body">
    {tabs.map((tab, i) => (
      <video
        class:list={["tab-video", { active: i === 0 }]}
        src={tab.video}
        preload={i === 0 ? "auto" : "none"}
        muted
        loop
        playsinline
        autoplay={i === 0}
        draggable="false"
        aria-label={tab.label}
      />
    ))}
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-video-tabs]").forEach(videoTabs => {
    const tabs   = videoTabs.querySelectorAll<HTMLButtonElement>(".tab");
    const videos = videoTabs.querySelectorAll<HTMLVideoElement>(".tab-video");
    const initialVideo = videoTabs.querySelector<HTMLVideoElement>(".tab-video.active");

    function playVideo(video: HTMLVideoElement) {
      if (video.preload === "none") video.preload = "auto";
      video.play().catch(() => {});
    }

    if (initialVideo) playVideo(initialVideo);

    // Pause / resume active video on scroll in/out of view
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          const active = videoTabs.querySelector<HTMLVideoElement>(".tab-video.active");
          if (!active) return;
          if (entry.isIntersecting) {
            playVideo(active);
          } else {
            active.pause();
          }
        });
      },
      { threshold: 0.2 }
    );
    observer.observe(videoTabs);

    function scheduleIdlePreload() {
      // Skip on mobile — loading 5 webM files simultaneously causes memory pressure
      // that triggers a browser page reload. Videos load on-demand via tab clicks instead.
      if (window.innerWidth < 768) return;

      videos.forEach((video, i) => {
        if (i === 0) return;
        const load = () => { video.preload = "auto"; };
        if ("requestIdleCallback" in window) {
          (window as any).requestIdleCallback(load, { timeout: 5000 });
        } else {
          setTimeout(load, i * 800);
        }
      });
    }

    if (document.readyState === "complete") {
      scheduleIdlePreload();
    } else {
      window.addEventListener("load", scheduleIdlePreload, { once: true });
    }

    tabs.forEach((tab, i) => {
      tab.addEventListener("click", () => {
        const prevVideo = videoTabs.querySelector<HTMLVideoElement>(".tab-video.active");
        prevVideo?.pause();

        tabs.forEach(t => { t.classList.remove("active"); t.setAttribute("aria-selected", "false"); });
        videos.forEach(v => v.classList.remove("active"));

        tab.classList.add("active");
        tab.setAttribute("aria-selected", "true");

        const nextVideo = videos[i] as HTMLVideoElement;
        nextVideo.classList.add("active");

        playVideo(nextVideo);
      });
    });
  });
</script>

<style>
  .video-tabs {
    display: contents;
  }

  .panel-header {
    padding: 10px 14px;
    background: var(--ivory);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .traffic-lights {
    display: flex;
    align-items: center;
    gap: 5px;
    flex-shrink: 0;
  }

  .panel-dot { width: 10px; height: 10px; border-radius: 50%; }
  .panel-dot-red    { background: #ff5f57; }
  .panel-dot-yellow { background: #ffbd2e; }
  .panel-dot-gold   { background: #c9a84c; }

  .panel-body {
    position: relative;
    background: var(--ivory2);
    aspect-ratio: 16 / 7;
    overflow: hidden;
  }

  .tab-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }
  .tab-video.active { opacity: 1; }

  :global(html.dark) .panel-header {
    background: rgba(14, 20, 36, 0.8);
    border-bottom-color: rgba(184, 148, 63, 0.18);
  }
  @media (max-width: 760px) {
    .panel-header { padding: 9px 12px; gap: 10px; }
    .panel-dot { width: 9px; height: 9px; }
    .panel-body { aspect-ratio: 16 / 8; }
  }

  @media (max-width: 480px) {
    .panel-body { aspect-ratio: 16 / 9; }
  }

  @media (max-width: 380px) {
    .panel-header { padding: 8px 10px; gap: 8px; }
    .panel-dot { width: 7px; height: 7px; }
    .traffic-lights { gap: 4px; }
  }
</style>
