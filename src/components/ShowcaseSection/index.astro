---
import type { Translations } from "../../i18n/translations";
import BudgetCard from "./BudgetCard.astro";
import SeatingCard from "./SeatingCard.astro";
import TimelineCard from "./TimelineCard.astro";

interface Props {
  t: Translations;
}
const { t } = Astro.props;
const { panels } = t.showcase;
---
<section class="showcase-section fade-in" id="showcase">
  <div class="showcase-text">
    <h2 class="serif">{t.showcase.headline}</h2>
    <p class="headline-script serif">{t.showcase.scriptLine}</p>
    <a href="#">{t.showcase.cta} →</a>
  </div>

  <div class="showcase-panels">
    <SeatingCard panel={panels.seating} />
    <TimelineCard panel={panels.timeline} />
    <BudgetCard panel={panels.budget} />
  </div>
</section>

<style>
  .showcase-section { padding: 72px 56px; background: var(--ivory2); border-bottom: 1px solid var(--border); display: grid; grid-template-columns: 220px 1fr; gap: 48px; align-items: start; }
  .showcase-text h2 { font-size: 28px; font-weight: 700; line-height: 1.3; margin-bottom: 12px; }
  .showcase-text .headline-script { font-style: italic; color: var(--teal-dark); font-size: 17px; margin: 10px 0 14px; line-height: 1.4; white-space: pre-line; }
  .showcase-text a { font-size: 13px; color: var(--teal-dark); font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 4px; }
  .showcase-panels { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
</style>
