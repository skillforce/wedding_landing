---
import type { Translations } from "../../i18n/translations";
import CtaFloralLeft from "../icons/CtaFloralLeft.astro";
import CtaFloralRight from "../icons/CtaFloralRight.astro";
import AppWindow from "./AppWindow.astro";

interface Props {
  t: Translations;
}
const { t } = Astro.props;

const tabVideos = [
  "/images/feature_example/guest_comp.webm",
  "/images/feature_example/seating_comp.webm",
  "/images/feature_example/budget_comp.webm",
  "/images/feature_example/checklist_comp.webm",
  "/images/feature_example/scenarion_comb.webm",
];
const tabs = t.showcase.tabs.map((label, i) => ({ label, video: tabVideos[i] }));
---
<section class="showcase-section fade-in" id="showcase">
  <div class="showcase-floral showcase-floral-left" aria-hidden="true">
    <CtaFloralLeft />
  </div>
  <div class="showcase-floral showcase-floral-right" aria-hidden="true">
    <CtaFloralRight />
  </div>

  <div class="showcase-text">
    <h2 class="serif">{t.showcase.headline}</h2>
    <p class="headline-script serif">{t.showcase.scriptLine}</p>
  </div>

  <div class="showcase-window">
    <AppWindow tabs={tabs} />
  </div>
</section>

<style>
  .showcase-section {
    padding: 72px 56px;
    background: var(--ivory2);
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 48px;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .showcase-floral {
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }

  .showcase-floral-left {
    left: 20px;
    top: 18px;
    width: 170px;
    height: 150px;
  }

  .showcase-floral-right {
    right: 22px;
    bottom: 6px;
    width: 150px;
    height: 130px;
  }

  .showcase-text,
  .showcase-window {
    position: relative;
    z-index: 1;
  }

  .showcase-text h2 {
    font-size: 30px;
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: 12px;
    text-wrap: balance;
  }

  .showcase-text .headline-script {
    max-width: 320px;
    font-style: italic;
    color: var(--teal-dark);
    font-size: 17px;
    margin: 0;
    line-height: 1.45;
    text-wrap: balance;
  }

  :global(html.dark) .showcase-text .headline-script { color: var(--gold); }

  @media (max-width: 1080px) {
    .showcase-section {
      grid-template-columns: 240px 1fr;
      gap: 28px;
      padding: 64px 36px;
    }

    .showcase-floral-left { left: 8px; top: 24px; }
    .showcase-floral-right { right: 8px; bottom: -8px; }
    .showcase-text h2 { font-size: 28px; }
  }

  @media (max-width: 760px) {
    .showcase-section {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 56px 24px;
    }

    .showcase-floral-left { left: -18px; top: 8px; width: 140px; height: 125px; }
    .showcase-floral-right { right: -18px; bottom: 6px; width: 120px; height: 105px; }
    .showcase-text { text-align: center; }
    .showcase-text h2 { font-size: 26px; }
    .showcase-text .headline-script {
      max-width: 420px;
      margin: 0 auto;
      text-align: center;
      white-space: normal;
      text-wrap: balance;
    }
  }

  .showcase-window { min-width: 0; display: flex; justify-content: center; }

  @media (max-width: 480px) {
    .showcase-section { padding: 48px 16px; }
    .showcase-text h2 { font-size: 24px; }
    .showcase-text .headline-script { font-size: 15px; line-height: 1.5; }
  }

  @media (max-width: 380px) {
    .showcase-section { padding: 40px 10px; }
  }
</style>
