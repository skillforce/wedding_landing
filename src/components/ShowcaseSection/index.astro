---
import type { Translations } from "../../i18n/translations";
import AppWindow from "./AppWindow.astro";

interface Props {
  t: Translations;
}
const { t } = Astro.props;

const tabVideos = [
  "/images/feature_example/scenarion_comb.webm",
  "/images/feature_example/guest_comp.webm",
  "/images/feature_example/seating_comp.webm",
  "/images/feature_example/budget_comp.webm",
  "/images/feature_example/checklist_comp.webm",
];
const tabs = t.showcase.tabs.map((label, i) => ({ label, video: tabVideos[i] }));
---
<section class="showcase-section fade-in" id="showcase">
  <div class="showcase-text">
    <h2 class="serif">{t.showcase.headline}</h2>
    <p class="headline-script serif">{t.showcase.scriptLine}</p>
    <a href="#">{t.showcase.cta} →</a>
  </div>

  <div class="showcase-window">
    <AppWindow tabs={tabs} />
  </div>
</section>

<style>
  .showcase-section {
    padding: 72px 56px;
    background: var(--ivory2);
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
    align-items: center;
  }
  .showcase-text h2 { font-size: 28px; font-weight: 700; line-height: 1.3; margin-bottom: 12px; }
  .showcase-text .headline-script { font-style: italic; color: var(--teal-dark); font-size: 17px; margin: 10px 0 14px; line-height: 1.4; white-space: pre-line; }
  .showcase-text a { font-size: 13px; color: var(--teal-dark); font-weight: 600; text-decoration: none; display: flex; align-items: center; gap: 4px; }

  :global(html.dark) .showcase-text .headline-script { color: var(--gold); }
  :global(html.dark) .showcase-text a { color: var(--gold); }

  @media (max-width: 1080px) {
    .showcase-section { grid-template-columns: 190px 1fr; gap: 28px; padding: 64px 36px; }
  }

  @media (max-width: 760px) {
    .showcase-section { grid-template-columns: 1fr; gap: 24px; padding: 56px 24px; }
    .showcase-text { text-align: center; }
    .showcase-text h2 { font-size: 26px; }
    .showcase-text .headline-script { text-align: center; white-space: normal; text-wrap: balance; }
    .showcase-text a { justify-content: center; }
  }

  .showcase-window { min-width: 0; }

  @media (max-width: 480px) {
    .showcase-section { padding: 48px 16px; }
    .showcase-text h2 { font-size: 24px; }
    .showcase-text .headline-script { font-size: 15px; }
  }

  @media (max-width: 380px) {
    .showcase-section { padding: 40px 10px; }
  }
</style>