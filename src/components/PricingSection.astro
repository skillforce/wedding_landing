---
import type { Translations } from "../i18n/translations";
import PricingCard from "./cards/PricingCard.astro";

interface Props {
  t: Translations;
}
const { t } = Astro.props;
---
<section class="pricing-section fade-in" id="pricing">
  <div class="pricing-headline">
    <h2 class="serif">{t.pricing.headline}</h2>
    <p class="headline-script serif">{t.pricing.scriptLine}</p>
  </div>

  <div class="pricing-content">
    <div class="pricing-cards">
      {t.pricing.plans.map(plan => (
        <PricingCard plan={plan} />
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-section { padding: 72px 56px; border-bottom: 1px solid var(--border); display: grid; grid-template-columns: 1fr; gap: 32px; }
  .pricing-headline { max-width: 620px; margin: 0 auto; text-align: center; }
  .pricing-headline h2 { font-size: 32px; font-weight: 700; line-height: 1.25; margin-bottom: 10px; }
  .pricing-headline .headline-script { font-style: italic; font-size: 17px; color: var(--gold); line-height: 1.4; white-space: pre-line; text-align: center; }
  .pricing-content { position: relative; }
  .pricing-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; align-items: start; }

  .pricing-quote-label { font-size: 8.5px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }
  .pricing-quote-text { font-style: italic; font-size: 12.5px; line-height: 1.6; color: rgba(255,255,255,.9); }

  @media (max-width: 1080px) {
    .pricing-section { gap: 28px; padding: 64px 36px; }
    .pricing-cards { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 760px) {
    .pricing-section { gap: 24px; padding: 56px 24px; }
    .pricing-headline h2 { font-size: 28px; }
    .pricing-headline .headline-script { text-align: center; white-space: normal; text-wrap: balance; }
  }

  @media (max-width: 560px) {
    .pricing-section { padding: 48px 16px; }
    .pricing-headline h2 { font-size: 25px; }
    .pricing-headline .headline-script { font-size: 15px; }
    .pricing-cards { grid-template-columns: 1fr; gap: 14px; }
  }
</style>
