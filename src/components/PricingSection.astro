---
import type { Translations } from "../i18n/translations";
import PricingCard from "./cards/PricingCard.astro";
import CtaFloralLeft from "./icons/CtaFloralLeft.astro";
import CtaFloralRight from "./icons/CtaFloralRight.astro";
import PricingTracery from "./icons/PricingTracery.astro";

interface Props {
  t: Translations;
}
const { t } = Astro.props;
---
<section class="pricing-section fade-in" id="pricing">
  <div class="pricing-tracery-wrap" aria-hidden="true">
    <PricingTracery />
  </div>
  <div class="pricing-floral pricing-floral-left" aria-hidden="true">
    <CtaFloralLeft />
  </div>
  <div class="pricing-floral pricing-floral-right" aria-hidden="true">
    <CtaFloralRight />
  </div>

  <div class="pricing-headline">
    <h2 class="serif">{t.pricing.headline}</h2>
    <p class="headline-script serif">{t.pricing.scriptLine}</p>
  </div>

  <div class="pricing-content">
    <div class="pricing-cards">
      {t.pricing.plans.map(plan => (
        <PricingCard plan={plan} />
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-section { padding: 72px 56px; border-bottom: 1px solid var(--border); display: grid; grid-template-columns: 1fr; gap: 32px; position: relative; overflow: hidden; isolation: isolate; }
  .pricing-tracery-wrap { position: absolute; left: 50%; top: 50%; width: min(1420px, 148vw); height: min(800px, 150%); transform: translate(-50%, -50%); pointer-events: none; z-index: 0; }
  .pricing-tracery-wrap::before {
    content: "";
    position: absolute;
    inset: 8% 6%;
    background: radial-gradient(circle at 50% 48%, rgba(42,78,74,.08), transparent 58%);
    filter: blur(18px);
  }
  :global(html.dark) .pricing-tracery-wrap::before {
    background: radial-gradient(circle at 50% 48%, rgba(226,185,106,.1), transparent 60%);
  }
  .pricing-floral { position: absolute; pointer-events: none; z-index: 1; }
  .pricing-floral-left { left: 7%; bottom: 26px; width: 150px; height: 140px; transform: rotate(-10deg); }
  .pricing-floral-right { right: 9%; top: 34px; width: 130px; height: 120px; transform: rotate(8deg); }
  .pricing-headline { max-width: 620px; margin: 0 auto; text-align: center; position: relative; z-index: 2; }
  .pricing-headline h2 { font-size: 32px; font-weight: 700; line-height: 1.25; margin-bottom: 10px; }
  .pricing-headline .headline-script { font-style: italic; font-size: 17px; color: var(--gold); line-height: 1.4; white-space: pre-line; text-align: center; }
  .pricing-content { position: relative; z-index: 2; }
  .pricing-cards { display: grid; grid-template-columns: repeat(2, minmax(0, 360px)); gap: 30px; align-items: start; justify-content: center; }

  .pricing-quote-label { font-size: 8.5px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }
  .pricing-quote-text { font-style: italic; font-size: 12.5px; line-height: 1.6; color: rgba(255,255,255,.9); }

  @media (max-width: 1080px) {
    .pricing-section { gap: 28px; padding: 64px 36px; }
    .pricing-floral-left { left: 24px; bottom: 18px; }
    .pricing-floral-right { right: 18px; top: 24px; }
  }

  @media (max-width: 760px) {
    .pricing-section { gap: 24px; padding: 56px 24px; }
    .pricing-tracery-wrap { width: calc(100% - 24px); height: calc(100% - 24px); }
    .pricing-floral-left { left: -20px; bottom: 92px; width: 120px; height: 110px; }
    .pricing-floral-right { right: -18px; top: 18px; width: 110px; height: 100px; }
    .pricing-headline h2 { font-size: 28px; }
    .pricing-headline .headline-script { text-align: center; white-space: normal; text-wrap: balance; }
  }

  @media (max-width: 560px) {
    .pricing-section { padding: 48px 16px; }
    .pricing-tracery-wrap { width: calc(100% - 16px); height: calc(100% - 16px); }
    .pricing-floral-left { bottom: 150px; }
    .pricing-headline h2 { font-size: 25px; }
    .pricing-headline .headline-script { font-size: 15px; }
    .pricing-cards { grid-template-columns: 1fr; gap: 14px; max-width: 400px; margin: 0 auto; }
  }
</style>
