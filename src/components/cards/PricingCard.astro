---
import type { Translations } from "../../i18n/translations";
import Button from "../base/Button.astro";
import { ButtonType } from "../base/Button.types";
import IconMoney from "../icons/IconMoney.astro";

type PricingPlan = Translations["pricing"]["plans"][number];

interface Props {
  plan: PricingPlan;
}

const { plan } = Astro.props;
---

<div class:list={['pricing-card', { featured: plan.featured }]}>
  {plan.badge && <div class="pricing-badge">{plan.badge}</div>}
  <div class="pricing-plan serif">{plan.name}</div>
  <div class="pricing-plan-sub">{plan.sub}</div>
  <div class="pricing-price">
    <span class="currency">$</span>
    <span class="amount serif">{plan.price}</span>
    <span class="period">/ {plan.period}</span>
  </div>
  <p class="pricing-desc">{plan.desc}</p>
  <Button
    type={plan.featured ? ButtonType.Primary : ButtonType.Secondary}
    size="compact"
    fullWidth
  >
    <IconMoney />
    {plan.cta}
  </Button>
</div>

<style>
  .pricing-card { background: #fff; border: 1px solid var(--border); border-radius: 16px; padding: 28px 24px; box-shadow: 0 2px 12px rgba(0,0,0,.04); position: relative; isolation: isolate; transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s; }
  .pricing-card::before {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, rgba(185,135,95,.14), rgba(201,168,76,.62), rgba(42,78,74,.18));
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask-composite: exclude;
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    opacity: .46;
    animation: pricing-glow 4.8s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
  }
  .pricing-card::after {
    content: "";
    position: absolute;
    inset: -7px;
    border-radius: 22px;
    border: 1px solid rgba(201,168,76,.36);
    box-shadow: 0 0 0 1px rgba(185,135,95,.08), 0 0 26px rgba(201,168,76,.2);
    opacity: .38;
    transform: scale(.985);
    animation: pricing-halo 4.8s ease-in-out infinite;
    pointer-events: none;
    z-index: -1;
  }
  .pricing-card.featured { border-color: var(--teal-dark); box-shadow: 0 8px 32px rgba(185,135,95,.2); }
  .pricing-card.featured::before { opacity: .82; background: linear-gradient(135deg, rgba(185,135,95,.18), rgba(201,168,76,.72), rgba(226,185,106,.3)); }
  .pricing-card:hover { transform: translateY(-4px); box-shadow: 0 10px 30px rgba(185,135,95,.16); }
  .pricing-plan { font-size: 16px; font-weight: 700; margin-bottom: 4px; }
  .pricing-plan-sub { font-size: 12px; color: var(--text-soft); font-style: italic; margin-bottom: 16px; }
  .pricing-price { display: flex; align-items: baseline; gap: 4px; margin-bottom: 4px; }
  .pricing-price .amount { font-size: 42px; font-weight: 700; line-height: 1; }
  .pricing-price .currency { font-size: 18px; font-weight: 700; align-self: start; margin-top: 6px; }
  .pricing-price .period { font-size: 12px; color: var(--text-soft); margin-left: 2px; }
  .pricing-desc { font-size: 15px; color: var(--text-mid); margin: 20px 0; line-height: 1.5; }
  .pricing-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--teal-dark); color: #fff; font-size: 10px; font-weight: 700; padding: 3px 12px; border-radius: 10px; letter-spacing: 0.5px; white-space: nowrap; }
  :global(html.dark) .pricing-card { background: rgba(26,37,64,.92); border-color: rgba(184,148,63,.22); box-shadow: 0 8px 28px rgba(0,0,0,.18); }
  :global(html.dark) .pricing-card.featured { border-color: var(--gold); box-shadow: 0 10px 36px rgba(201,168,76,.18); }
  :global(html.dark) .pricing-card:hover { box-shadow: 0 12px 34px rgba(0,0,0,.26); }
  :global(html.dark) .pricing-card::before { background: linear-gradient(135deg, rgba(226,185,106,.08), rgba(226,185,106,.52), rgba(255,255,255,.07)); opacity: .56; }
  :global(html.dark) .pricing-card::after { border-color: rgba(226,185,106,.34); box-shadow: 0 0 0 1px rgba(226,185,106,.08), 0 0 30px rgba(226,185,106,.2); }
  :global(html.dark) .pricing-card.featured::before { opacity: .88; background: linear-gradient(135deg, rgba(226,185,106,.16), rgba(226,185,106,.78), rgba(255,255,255,.1)); }
  :global(html.dark) .pricing-plan { color: var(--text-dark); }
  :global(html.dark) .pricing-desc { color: var(--text-mid); }
  :global(html.dark) .pricing-price { color: var(--text-dark); }
  :global(html.dark) .pricing-badge { background: var(--gold); color: var(--navy); }

  @media (max-width: 480px) {
    .pricing-card { padding: 24px 18px 20px; }
    .pricing-price .amount { font-size: 36px; }
    .pricing-badge { max-width: calc(100% - 24px); overflow: hidden; text-overflow: ellipsis; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pricing-card::before,
    .pricing-card::after {
      animation: none;
    }
  }

  @keyframes pricing-glow {
    0%, 100% { opacity: .36; }
    50% { opacity: .8; }
  }

  @keyframes pricing-halo {
    0%, 100% { opacity: .28; transform: scale(.985); }
    50% { opacity: .72; transform: scale(1.015); }
  }
</style>
