---
import type { Translations } from "../i18n/translations";
import Button from "./base/Button.astro";
import { ButtonType } from "./base/Button.types";
import HeroFloralDark from "./icons/HeroFloralDark.astro";
import HeroFloralLight from "./icons/HeroFloralLight.astro";
import IconBoxPlus from "./icons/IconBoxPlus.astro";
import IconStar from "./icons/IconStar.astro";

interface Props {
  t: Translations;
}
const { t } = Astro.props;
---
<section class="hero">
  <HeroFloralLight />
  <HeroFloralDark />

  <div class="hero-ambient"></div>
  <div class="hero-stars">
    <div class="hero-star hero-star-1"></div>
    <div class="hero-star hero-star-2"></div>
    <div class="hero-star hero-star-3"></div>
  </div>

  <p class="hero-eyebrow">{t.hero.eyebrow}</p>
  <span class="hero-title-line1 serif">We plan.</span>
  <span class="hero-title-line2 script">You celebrate.</span>
  <p class="hero-sub">{t.hero.subtitle}</p>

  <div class="hero-btns">
    <Button type={ButtonType.Primary}>
      <IconStar size={14} />{t.hero.ctaPrimary}
    </Button>
    <Button type={ButtonType.Secondary}>
      <IconBoxPlus size={14} />{t.hero.ctaSecondary}
    </Button>
  </div>

  <div class="hero-editorial">
    <div class="hero-editorial-label">WEDDING TIMES</div>
    <div class="hero-editorial-text serif">A day to remember</div>
  </div>

  <div class="creep-line"></div>
</section>

<style>
  .hero {
    min-height: 520px; position: relative; overflow: hidden;
    padding: 60px 48px 48px 56px;
    background-image: url("/images/hero_background_white.avif");
    background-position: center;
    background-size: cover;
    background-repeat: no-repeat;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  :global(html.dark) .hero {
    background-image: url("/images/hero_background_dark.avif");
  }

  .hero-ambient { position: absolute; left: 0; bottom: 0; width: 280px; height: 200px; background: radial-gradient(ellipse at 20% 100%, rgba(184,148,63,.18) 0%, transparent 65%); pointer-events: none; display: none; }
  :global(html.dark) .hero-ambient { display: block; }
  .hero-stars { position: absolute; inset: 0; pointer-events: none; overflow: hidden; display: none; }
  :global(html.dark) .hero-stars { display: block; }
  .hero-star { position: absolute; border-radius: 50%; }
  .hero-star-1 { width: 2px; height: 2px; background: rgba(184,148,63,.5); top: 18%; left: 70%; }
  .hero-star-2 { width: 1.5px; height: 1.5px; background: rgba(184,148,63,.4); top: 32%; left: 85%; }
  .hero-star-3 { width: 2px; height: 2px; background: rgba(255,255,255,.25); top: 55%; left: 78%; }

  .hero-eyebrow { font-size: 11px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; margin-bottom: 16px; color: var(--text-soft); transition: color 0.2s; }
  :global(html.dark) .hero-eyebrow { color: var(--gold); opacity: 0.8; }
  .hero-title-line1 { font-size: 52px; font-weight: 700; line-height: 1.1; display: block; color: var(--text-dark); transition: color 0.2s; }
  .hero-title-line2 { font-size: 68px; line-height: 1.1; display: block; margin-bottom: 20px; color: var(--teal-dark); transition: color 0.2s; }
  :global(html.dark) .hero-title-line1 { color: #fff; }
  :global(html.dark) .hero-title-line2 { color: var(--gold-bright); }
  .hero-sub { font-size: 14.5px; line-height: 1.65; max-width: 380px; margin: 0 auto 28px; color: var(--text-mid); transition: color 0.2s; }
  :global(html.dark) .hero-sub { color: #9ba8c0; }

  .hero-btns { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }

  .hero-editorial { position: absolute; right: 40px; bottom: 60px; background: rgba(255,255,255,.9); border: 1px solid var(--border); padding: 8px 14px; transform: rotate(-2deg); box-shadow: 2px 3px 12px rgba(0,0,0,.08); transition: background 0.2s, border-color 0.2s; }
  :global(html.dark) .hero-editorial { background: rgba(30,45,74,.9); border-color: rgba(184,148,63,.3); transform: rotate(2deg); }
  .hero-editorial-label { font-size: 8px; letter-spacing: 2px; color: #999; margin-bottom: 2px; }
  :global(html.dark) .hero-editorial-label { letter-spacing: 2.5px; color: var(--gold); opacity: 0.75; }
  .hero-editorial-text { font-style: italic; font-size: 11px; color: var(--text-dark); line-height: 1.4; }
  :global(html.dark) .hero-editorial-text { color: rgba(255,255,255,.85); }

  .creep-line { position: absolute; bottom: 0; left: 0; width: 200%; height: 1.5px; background: linear-gradient(90deg, transparent, var(--teal-dark), transparent); animation: creep 4s linear infinite; opacity: 0.4; transition: background 0.2s; }
  :global(html.dark) .creep-line { background: linear-gradient(90deg, transparent, var(--gold), transparent); }
  @keyframes creep { from { transform: translateX(-50%); } to { transform: translateX(0%); } }
</style>
