---
import type { Translations } from "../i18n/translations";
import FeatureCard from "./cards/FeatureCard.astro";
import FeaturesHeadlineTracery from "./icons/FeaturesHeadlineTracery.astro";

interface Props {
  t: Translations;
}
const { t } = Astro.props;
---
<section class="features-section fade-in" id="features">
  <div class="features-headline">
    <div class="features-tracery-wrap" aria-hidden="true">
      <FeaturesHeadlineTracery />
    </div>
    <div class="features-headline-content">
      <h2 class="serif">{t.features.headline}</h2>
      <p class="headline-script serif">{t.features.scriptLine}</p>
    </div>
  </div>
  <div class="features-cards">
    {t.features.cards.map(card => (
      <FeatureCard card={card} />
    ))}
  </div>
</section>

<style>
  .features-section { display: grid; grid-template-columns: 1fr; gap: 32px; padding: 20px; border-bottom: 1px solid var(--border)  }
  .features-headline { max-width: 680px; width: 100%; margin: 0 auto; text-align: center; position: relative; isolation: isolate; padding: 22px 36px 36px; overflow: hidden; }
  .features-headline { top: 10px; align-self: start; }
  .features-tracery-wrap { position: absolute; left: 50%; top: 50%; width: 128%; height: 132%; transform: translate(-50%, -50%); pointer-events: none; z-index: 0; }
  .features-tracery-wrap::before {
    content: "";
    position: absolute;
    inset: 18% 14%;
    background: radial-gradient(circle at 50% 52%, rgba(42,78,74,.06), transparent 64%);
    filter: blur(16px);
  }
  :global(html.dark) .features-tracery-wrap::before {
    background: radial-gradient(circle at 50% 52%, rgba(226,185,106,.08), transparent 66%);
  }
  .features-headline-content { position: relative; z-index: 1; max-width: 560px; margin: 0 auto; }
  .features-headline h2 { font-size: 32px; font-weight: 700; line-height: 1.25; }
  .headline-script { display: -webkit-box; overflow: hidden; -webkit-box-orient: vertical; -webkit-line-clamp: 2; font-style: italic; color: var(--teal-dark); font-size: 17px; margin-top: 12px; line-height: 1.4; white-space: pre-line; }
  .features-cards { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; }

  @media (max-width: 1180px) {
    .features-section { gap: 28px; padding: 64px 36px; }
    .features-cards { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }

  @media (max-width: 760px) {
    .features-section { gap: 24px; padding: 56px 24px; }
    .features-headline { max-width: none; padding: 34px 20px 30px; }
    .features-tracery-wrap { width: 100%; height: 100%; }
    .features-headline { position: relative; }
    .features-headline h2 { font-size: 28px; }
    .headline-script { text-align: center; white-space: normal; text-wrap: balance; }
    .features-cards { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 480px) {
    .features-section { padding: 15px; }
    .features-headline { padding: 30px 10px 26px; }
    .features-tracery-wrap { width: 100%; height: 100%; }
    .features-headline h2 { font-size: 25px; }
    .headline-script { font-size: 15px; }
    .features-cards { grid-template-columns: 1fr; gap: 12px; }
  }
</style>
