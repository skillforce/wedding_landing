---
import type { Translations } from "../i18n/translations";
import SiteLogo from "./SiteLogo.astro";

interface Props {
  t: Translations;
}
const { t } = Astro.props;
const fn = t.footer.nav;

const footerLinks = [
  { label: fn.features, href: "#features" },
  { label: fn.forWho, href: "#forwho" },
  { label: fn.pricing, href: "#pricing" },
];

const socialLinks = [
  { label: "𝕏", href: "#" },
  { label: "in", href: "#" },
  { label: "📸", href: "#" },
  { label: "f", href: "#" },
];
---
<footer>
  <div class="footer-inner">
    <SiteLogo variant="footer" />

    <nav class="footer-links">
      {footerLinks.map(({ label, href }) => (
        <a href={href}>{label}</a>
      ))}
    </nav>
  </div>

  <div class="footer-bottom">
    <p>{t.footer.copyright}</p>
    <img
      class="provider-logo"
      src="/images/logo/provider_logo.avif"
      alt="Provider logo"
      width="100"
      height="100"
      loading="lazy"
    />
  </div>
</footer>

<style>
  footer { padding: 40px 56px 24px; border-top: 1px solid var(--border); background: var(--ivory); transition: background 0.2s, border-color 0.2s; }
  :global(html.dark) footer { background: var(--navy2); border-top-color: var(--border); }

  .footer-inner { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 32px; margin-bottom: 28px; }

  .footer-links { display: flex; justify-content: center; gap: 28px; flex-wrap: wrap; grid-column: 2; }
  .footer-links a { font-size: 12.5px; color: var(--text-soft); text-decoration: none; transition: 0.15s; }
  .footer-links a:hover { color: var(--text-dark); }


  .footer-bottom { border-top: 1px solid var(--border); padding-top: 18px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; }
  .footer-bottom p { font-size: 11px; color: var(--text-soft); }
  .provider-logo { display: block; width: 100px; height: 100px; object-fit: contain; }

  @media (max-width: 760px) {
    footer { padding: 36px 24px 22px; }
    .footer-inner { gap: 22px; }
    .footer-links { gap: 14px 20px; }
    .provider-logo { width: 70px; height: 70px; }
  }

  @media (max-width: 480px) {
    footer { padding: 32px 16px 20px; }
    .footer-inner { display: flex; flex-direction: column; margin-bottom: 22px; }
    .footer-links { align-self: center; text-align: center; }
    .footer-social { gap: 8px; align-self: center; }
    .footer-bottom { align-items: center; flex-direction: column-reverse; }
  }
</style>
