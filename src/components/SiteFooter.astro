---
import type { Translations } from "../i18n/translations";
import SiteLogo from "./SiteLogo.astro";

interface Props {
  t: Translations;
}
const { t } = Astro.props;
---
<footer>
  <div class="footer-inner">
    <SiteLogo variant="footer" />
    <p class="footer-copy">{t.footer.copyright}</p>
    <img
      class="provider-logo"
      src="/images/logo/provider_logo.avif"
      alt="Provider logo"
      width="100"
      height="100"
      loading="lazy"
    />
  </div>
</footer>

<style>
  footer { padding: 32px 56px; border-top: 1px solid var(--border); background: var(--ivory); transition: background 0.2s, border-color 0.2s; }
  :global(html.dark) footer { background: var(--navy2); border-top-color: var(--border); }

  .footer-inner { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 32px; }
  .footer-copy { justify-self: center; font-size: 14px; color: var(--text-soft); }
  .provider-logo { display: block; width: 100px; height: 100px; object-fit: contain; justify-self: end; }

  @media (max-width: 760px) {
    footer { padding: 28px 24px; }
    .footer-inner { gap: 22px; }
    .provider-logo { width: 70px; height: 70px; }
  }

  @media (max-width: 480px) {
    footer { padding: 28px 16px; }
    .footer-inner { display: flex; flex-direction: column; }
  }
</style>
